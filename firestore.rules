
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isInstitutionalEmail() {
      return isSignedIn() && 
             request.auth.token.email != null && 
             request.auth.token.email.endsWith('@neu.edu.ph');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(uid) {
      let path = /databases/$(database)/documents/users/$(uid);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() {
      let data = getUserData(request.auth.uid);
      return isSignedIn() && data != null && data.role == 'Admin';
    }

    function isNotBlocked() {
      let data = getUserData(request.auth.uid);
      return isSignedIn() && (data == null || data.isBlocked == false);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isInstitutionalEmail();
      allow update: if (isOwner(userId) && isNotBlocked() && 
                      request.resource.data.role == resource.data.role && 
                      request.resource.data.isBlocked == resource.data.isBlocked) || isAdmin();
      allow delete: if isAdmin();
    }

    match /lab_usage/{logId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (
        isAdmin() || 
        (resource.data.userId == request.auth.uid)
      );
      allow create: if isSignedIn() && isNotBlocked() && 
                    isInstitutionalEmail() &&
                    request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
