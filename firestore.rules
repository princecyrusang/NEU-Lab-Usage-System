
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isInstitutionalEmail() {
      return isSignedIn() && 
             request.auth.token.email != null && 
             request.auth.token.email.matches('(?i).*@neu\\.edu\\.ph$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && userDoc != null && userDoc.data.role == 'Admin';
    }

    match /users/{userId} {
      allow read: if isInstitutionalEmail();
      allow create, update: if (isOwner(userId) && isInstitutionalEmail()) || isAdmin();
      allow delete: if isAdmin();
    }

    match /lab_usage/{logId} {
      allow read: if isInstitutionalEmail();
      allow create: if isInstitutionalEmail();
      allow update, delete: if isAdmin();
    }

    match /active_sessions/{roomId} {
      allow read: if isInstitutionalEmail();
      // Allow creation only if the room isn't already occupied
      allow create: if isInstitutionalEmail() && !exists(/databases/$(database)/documents/active_sessions/$(roomId));
      // Allow deletion by the occupant or an admin
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
  }
}
