
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isNotBlocked() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && (!exists(path) || get(path).data.isBlocked == false);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId);
      
      allow update: if (isOwner(userId) && isNotBlocked() && 
                      request.resource.data.role == resource.data.role && 
                      request.resource.data.isBlocked == resource.data.isBlocked) || isAdmin();
      
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for library visits (top-level collection).
     */
    match /visits/{visitId} {
      // Single document read
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // List rules with query constraints:
      // Admins can list everything.
      // Regular users MUST provide a filter where userId matches their own UID.
      allow list: if isSignedIn() && (
        isAdmin() || 
        (request.query.filters != null && request.query.filters.userId == request.auth.uid)
      );
      
      // Users can only create visits for themselves if not blocked
      allow create: if isSignedIn() && isNotBlocked() && request.resource.data.userId == request.auth.uid;
      
      // Only admins can modify or delete visit records
      allow update, delete: if isAdmin();
    }
  }
}
