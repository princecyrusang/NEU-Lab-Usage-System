rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isInstitutionalEmail() {
      // Use case-insensitive regex for robust domain validation
      return isSignedIn() && 
             request.auth.token.email != null && 
             request.auth.token.email.matches('(?i).*@neu\\.edu\\.ph$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(uid) {
      let path = /databases/$(database)/documents/users/$(uid);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() {
      // Optimized check: return false immediately if not signed in
      if (!isSignedIn()) return false;
      let data = getUserData(request.auth.uid);
      return data != null && data.role == 'Admin';
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Allow individual access or institutional listing for dashboard counts
      allow read: if isOwner(userId) || isInstitutionalEmail() || isAdmin();
      
      // Allow creation and update for institutional users on their own doc
      allow create, update: if (isOwner(userId) && isInstitutionalEmail()) || isAdmin();
      
      allow delete: if isAdmin();
    }

    match /lab_usage/{logId} {
      // Allow all institutional users to read logs for the System Monitor dashboards
      allow read: if isInstitutionalEmail();
      
      // Allow logging of usage sessions
      allow create: if isInstitutionalEmail() &&
                    request.resource.data.userId == request.auth.uid;
                    
      allow update, delete: if isAdmin();
    }
  }
}