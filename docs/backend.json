
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a professor or faculty member's profile.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string" },
        "collegeOffice": { "type": "string" },
        "isSetupComplete": { "type": "boolean" },
        "isBlocked": { "type": "boolean" }
      },
      "required": ["id", "email", "fullName", "role", "collegeOffice", "isSetupComplete", "isBlocked"]
    },
    "LabUsage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LabUsage",
      "type": "object",
      "description": "Historical record of laboratory usage.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "collegeOffice": { "type": "string" },
        "roomNumber": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "number" }
      },
      "required": ["userId", "fullName", "email", "collegeOffice", "roomNumber", "startTime", "endTime"]
    },
    "ActiveSession": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ActiveSession",
      "type": "object",
      "description": "Currently active laboratory usage session.",
      "properties": {
        "roomId": { "type": "string", "description": "The normalized name of the room." },
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "collegeOffice": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" }
      },
      "required": ["roomId", "userId", "fullName", "startTime"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User profiles for faculty and administrators."
        }
      },
      {
        "path": "/lab_usage/{logId}",
        "definition": {
          "entityName": "LabUsage",
          "schema": { "$ref": "#/backend/entities/LabUsage" },
          "description": "Historical usage logs."
        }
      },
      {
        "path": "/active_sessions/{roomId}",
        "definition": {
          "entityName": "ActiveSession",
          "schema": { "$ref": "#/backend/entities/ActiveSession" },
          "description": "Real-time room occupancy tracking."
        }
      }
    ]
  }
}
