
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a professor or faculty member's profile within the NEU Laboratory Usage Log system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity (Firebase UID)."
        },
        "email": {
          "type": "string",
          "description": "The user's institutional email address (@neu.edu.ph).",
          "format": "email"
        },
        "fullName": {
          "type": "string",
          "description": "The user's full name."
        },
        "role": {
          "type": "string",
          "description": "The role of the user (e.g., admin, professor)."
        },
        "collegeOffice": {
          "type": "string",
          "description": "The college or department the professor belongs to."
        },
        "isSetupComplete": {
          "type": "boolean",
          "description": "Onboarding status."
        },
        "isBlocked": {
          "type": "boolean",
          "description": "Access restriction status."
        }
      },
      "required": [
        "id",
        "email",
        "fullName",
        "role",
        "collegeOffice",
        "isSetupComplete",
        "isBlocked"
      ]
    },
    "LabUsage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LabUsage",
      "type": "object",
      "description": "Records a single usage log of a laboratory room by a professor.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string",
          "description": "Reference to the professor's UserProfile."
        },
        "fullName": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "collegeOffice": {
          "type": "string"
        },
        "roomNumber": {
          "type": "string",
          "description": "The laboratory room number being used."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "userId",
        "fullName",
        "email",
        "collegeOffice",
        "roomNumber",
        "timestamp"
      ]
    }
  },
  "auth": {
    "providers": [
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "User profiles for faculty and administrators."
        }
      },
      {
        "path": "/lab_usage/{logId}",
        "definition": {
          "entityName": "LabUsage",
          "schema": {
            "$ref": "#/backend/entities/LabUsage"
          },
          "description": "Global collection of laboratory usage logs."
        }
      }
    ],
    "reasoning": "Standardizing on a top-level collection for laboratory usage allows for comprehensive institutional reporting and simplified role-based security filtering."
  }
}
